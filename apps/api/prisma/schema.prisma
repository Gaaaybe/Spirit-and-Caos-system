// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// BOUNDED CONTEXT: ACCOUNTS
// ============================================

enum UserRole {
  PLAYER
  MASTER
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  password  String
  roles     UserRole[] @default([PLAYER])
  createdAt DateTime   @default(now())
  updatedAt DateTime?  @updatedAt

  peculiarities Peculiarity[]
  powers        Power[]
  powerArrays   PowerArray[]
  items         Item[]
  characters    Character[]

  @@map("users")
}

// ============================================
// BOUNDED CONTEXT: POWER-MANAGER
// ============================================

model Peculiarity {
  id         String    @id @default(uuid())
  userId     String
  nome       String
  descricao  String
  espiritual Boolean
  isPublic   Boolean   @default(false)
  icone      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime? @updatedAt

  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  powersWithDomain      Power[]      @relation("PeculiarityDomainPowers")
  powerArraysWithDomain PowerArray[] @relation("PeculiarityDomainPowerArrays")

  @@index([userId])
  @@index([isPublic])
  @@index([userId, isPublic])
  @@map("peculiarities")
}

enum DomainName {
  NATURAL
  SAGRADO
  SACRILEGIO
  PSIQUICO
  CIENTIFICO
  PECULIAR
  ARMA_BRANCA
  ARMA_FOGO
  ARMA_TENSAO
  ARMA_EXPLOSIVA
  ARMA_TECNOLOGICA
  DESARMADO
}

model Power {
  id          String  @id @default(uuid())
  userId      String? // NULL = poder oficial/sistema
  characterId String?
  nome        String
  descricao   String
  isPublic    Boolean @default(false)
  icone       String?
  notas       String?

  domainName             DomainName
  domainAreaConhecimento String?
  domainPeculiarId       String?

  parametrosAcao    Int @default(2)
  parametrosAlcance Int @default(1)
  parametrosDuracao Int @default(0)

  custoTotalPda     Int @default(0)
  custoTotalPe      Int @default(0)
  custoTotalEspacos Int @default(0)

  custoAlternativoTipo       String?
  custoAlternativoQuantidade Int?
  custoAlternativoDescricao  String?
  custoAlternativoAtributo   String?
  custoAlternativoItemId     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterInstance Character?       @relation("CharacterClonedPowers", fields: [characterId], references: [id], onDelete: Cascade)
  peculiarity      Peculiarity?      @relation("PeculiarityDomainPowers", fields: [domainPeculiarId], references: [id], onDelete: Restrict)
  appliedEffects   AppliedEffect[]
  powerArrayPowers PowerArrayPower[]
  characterPowers  CharacterPower[]

  @@index([userId])
  @@index([characterId])
  @@index([isPublic])
  @@index([userId, isPublic])
  @@index([domainName])
  @@index([domainPeculiarId])
  @@map("powers")
}

model PowerArray {
  id          String  @id @default(uuid())
  userId      String? // NULL = acervo oficial/sistema
  characterId String?
  nome        String
  descricao   String
  isPublic    Boolean @default(false)
  icone       String?
  notas       String?

  domainName             DomainName
  domainAreaConhecimento String?
  domainPeculiarId       String?

  parametrosBaseAcao    Int?
  parametrosBaseAlcance Int?
  parametrosBaseDuracao Int?

  custoTotalPda     Int @default(0)
  custoTotalPe      Int @default(0)
  custoTotalEspacos Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterInstance    Character?            @relation("CharacterClonedPowerArrays", fields: [characterId], references: [id], onDelete: Cascade)
  peculiarity          Peculiarity?          @relation("PeculiarityDomainPowerArrays", fields: [domainPeculiarId], references: [id], onDelete: Restrict)
  powerArrayPowers     PowerArrayPower[]
  itemPowerArrays      ItemPowerArray[]
  characterPowerArrays CharacterPowerArray[]

  @@index([userId])
  @@index([characterId])
  @@index([isPublic])
  @@index([userId, isPublic])
  @@index([domainName])
  @@index([domainPeculiarId])
  @@map("power_arrays")
}

enum ModificationScope {
  GLOBAL
  LOCAL
}

enum ModificationType {
  EXTRA
  FALHA
}

model AppliedEffect {
  id             String  @id @default(uuid())
  powerId        String
  effectBaseId   String
  grau           Int
  configuracaoId String?
  inputValue     String?
  nota           String?
  posicao        Int     @default(0)

  custoPda     Int @default(0)
  custoPe      Int @default(0)
  custoEspacos Int @default(0)

  appliedModifications AppliedModification[]

  power      Power      @relation(fields: [powerId], references: [id], onDelete: Cascade)
  effectBase EffectBase @relation(fields: [effectBaseId], references: [id], onDelete: Restrict)

  @@index([powerId])
  @@index([effectBaseId])
  @@map("applied_effects")
}

model AppliedModification {
  id                 String            @id @default(uuid())
  appliedEffectId    String
  modificationBaseId String
  scope              ModificationScope
  grau               Int               @default(1)
  parametros         Json?
  nota               String?
  posicao            Int               @default(0)

  appliedEffect    AppliedEffect    @relation(fields: [appliedEffectId], references: [id], onDelete: Cascade)
  modificationBase ModificationBase @relation(fields: [modificationBaseId], references: [id], onDelete: Restrict)

  @@index([appliedEffectId])
  @@index([modificationBaseId])
  @@index([scope])
  @@map("applied_modifications")
}

model PowerArrayPower {
  id           String @id @default(uuid())
  powerArrayId String
  powerId      String
  posicao      Int    @default(0)

  powerArray PowerArray @relation(fields: [powerArrayId], references: [id], onDelete: Cascade)
  power      Power      @relation(fields: [powerId], references: [id], onDelete: Cascade)

  @@unique([powerArrayId, powerId])
  @@index([powerArrayId])
  @@index([powerId])
  @@map("power_array_powers")
}

// ============================================
// BOUNDED CONTEXT: ITEM-MANAGER
// ============================================

enum ItemType {
  WEAPON
  DEFENSIVE_EQUIPMENT
  CONSUMABLE
  ARTIFACT
  ACCESSORY
  GENERAL
  UPGRADE_MATERIAL
}

enum WeaponRange {
  ADJACENTE
  NATURAL
  CURTO
  MEDIO
  LONGO
}

enum EquipmentType {
  TRAJE
  PROTECAO
}

enum DurabilityStatus {
  INTACTO
  DANIFICADO
}

enum SpoilageState {
  PERFEITA
  BOA
  NORMAL
  RUIM
  TERRIVEL
}

model Item {
  id           String           @id @default(uuid())
  userId       String? // NULL = item oficial/sistema
  characterId  String?
  tipo         ItemType
  nome         String
  descricao    String
  isPublic     Boolean          @default(false)
  icone        String?
  notas        String?
  durabilidade DurabilityStatus @default(INTACTO)
  canStack     Boolean          @default(false)
  maxStack     Int              @default(2)

  domainName             DomainName
  domainAreaConhecimento String?
  domainPeculiarId       String?

  custoBase Int
  nivelItem Int @default(1)

  // --- WEAPON ---
  critMargin                Int?
  critMultiplier            Int?
  alcance                   WeaponRange?
  alcanceExtraMetrosMetades Int?
  atributoEscalonamento     String?
  upgradeLevelValue         Int?
  upgradeLevelMax           Int?

  // --- DEFENSIVE EQUIPMENT ---
  tipoEquipamento EquipmentType?
  baseRD          Int?

  // --- CONSUMABLE ---
  descritorEfeito String?
  qtdDoses        Int?
  isRefeicao      Boolean?
  spoilageState   SpoilageState?

  // --- ARTIFACT ---
  isAttuned Boolean?

  // --- UPGRADE MATERIAL ---
  materialTier            Int?
  materialMaxUpgradeLimit Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  character       Character?       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemDamages     ItemDamage[]
  itemPowers      ItemPower[]
  itemPowerArrays ItemPowerArray[]

  @@index([userId])
  @@index([tipo])
  @@index([isPublic])
  @@index([userId, isPublic])
  @@index([domainName])
  @@map("items")
}

// ============================================
// BOUNDED CONTEXT: CHARACTER-MANAGER
// ============================================

enum SpiritualStage {
  NORMAL
  DIVINE
}

enum DeathState {
  ALIVE
  DYING
  DEAD
}

enum DomainMasteryLevel {
  INICIANTE
  PRATICANTE
  MESTRE
}

model Character {
  id        String   @id @default(uuid())
  userId    String
  level     Int      @default(1)
  inspiration Int    @default(0)

  attributes         Json
  narrativeProfile   Json
  skills             Json
  pdaState           Json
  healthState        Json
  energyState        Json
  spiritualPrinciple Json
  equipmentSlots     Json
  inventory          Json
  conditions         Json
  unarmedMastery     Json?

  deathState   DeathState @default(ALIVE)
  deathCounter Int        @default(0)

  symbol    String?
  art       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  powers             CharacterPower[]
  powerArrays        CharacterPowerArray[]
  benefits           CharacterBenefit[]
  domains            CharacterDomain[]
  items              Item[]
  clonedPowers       Power[]                @relation("CharacterClonedPowers")
  clonedPowerArrays  PowerArray[]           @relation("CharacterClonedPowerArrays")

  @@index([userId])
  @@index([userId, updatedAt])
  @@map("characters")
}

model CharacterPower {
  id          String  @id @default(uuid())
  characterId String
  powerId     String
  isEquipped  Boolean @default(false)
  finalPdaCost Int
  slotCost    Int
  posicao     Int

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  power     Power     @relation(fields: [powerId], references: [id], onDelete: Cascade)

  @@unique([characterId, powerId])
  @@index([characterId])
  @@index([powerId])
  @@map("character_powers")
}

model CharacterPowerArray {
  id            String  @id @default(uuid())
  characterId   String
  powerArrayId  String
  isEquipped    Boolean @default(false)
  finalPdaCost  Int
  slotCost      Int
  posicao       Int

  character  Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  powerArray PowerArray @relation(fields: [powerArrayId], references: [id], onDelete: Cascade)

  @@unique([characterId, powerArrayId])
  @@index([characterId])
  @@index([powerArrayId])
  @@map("character_power_arrays")
}

model CharacterBenefit {
  id          String @id @default(uuid())
  characterId String
  name        String
  degree      Int
  pdaCost     Int
  posicao     Int

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([name])
  @@map("character_benefits")
}

model CharacterDomain {
  id           String @id @default(uuid())
  characterId  String
  domainId     String
  masteryLevel DomainMasteryLevel

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, domainId])
  @@index([characterId])
  @@index([domainId])
  @@map("character_domains")
}

/// Tabela de danos de uma arma (tipo multivalorado, ordenado por posição)
model ItemDamage {
  id         String  @id @default(uuid())
  itemId     String
  dado       String
  base       String
  espiritual Boolean @default(false)
  posicao    Int     @default(0)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("item_damages")
}

/// Junction table: poderes associados a um item (IDs apenas)
model ItemPower {
  id      String @id @default(uuid())
  itemId  String
  powerId String
  posicao Int    @default(0)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, powerId])
  @@index([itemId])
  @@map("item_powers")
}

/// Junction table: acervos de poderes associados a um item
model ItemPowerArray {
  id           String @id @default(uuid())
  itemId       String
  powerArrayId String
  posicao      Int    @default(0)

  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  powerArray PowerArray @relation(fields: [powerArrayId], references: [id], onDelete: Cascade)

  @@unique([itemId, powerArrayId])
  @@index([itemId])
  @@map("item_power_arrays")
}

model EffectBase {
  id         String   @id
  nome       String
  custoBase  Int
  descricao  String
  categorias String[]
  exemplos   String?

  parametrosPadraoAcao    Int @default(2)
  parametrosPadraoAlcance Int @default(1)
  parametrosPadraoDuracao Int @default(0)

  requerInput      Boolean  @default(false)
  tipoInput        String?
  labelInput       String?
  opcoesInput      String[] @default([])
  placeholderInput String?

  // Contém: tipo, label, opcoes[] {id, nome, modificadorCusto, grauMinimo, descricao, custoProgressivo}
  configuracoes Json?

  custom Boolean @default(false)

  appliedEffects AppliedEffect[]

  @@index([custom])
  @@map("effect_bases")
}

model ModificationBase {
  id           String           @id
  nome         String
  tipo         ModificationType
  custoFixo    Int
  custoPorGrau Int
  descricao    String
  categoria    String
  observacoes  String?
  detalhesGrau String?

  requerParametros Boolean  @default(false)
  tipoParametro    String?
  opcoes           String[] @default([])
  grauMinimo       Int?
  grauMaximo       Int?
  placeholder      String?

  // Contém: tipo, label, opcoes[] {id, nome, modificadorCusto, modificadorCustoFixo, descricao}
  configuracoes Json?

  custom Boolean @default(false)

  appliedModifications AppliedModification[]

  @@index([tipo])
  @@index([categoria])
  @@index([custom])
  @@map("modification_bases")
}
